@model UserCreateModel

@{
    ViewData["Title"] = "Yeni Kullanıcı";
}

<div class="container py-5">

    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-dark text-white rounded-top-4">
                    <h4 class="mb-0">Yeni Kullanıcı Oluştur</h4>
                </div>

                <div class="card-body p-4">

                    <form asp-action="Create" method="post">

                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <!-- FULL NAME -->
                        <div class="mb-4">
                            <label asp-for="FullName" class="form-label fw-semibold">
                                Ad Soyad
                            </label>

                            <input asp-for="FullName" class="form-control form-control-lg rounded-3"
                                placeholder="Ad Soyad giriniz">

                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <!-- EMAIL -->
                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-semibold">
                                Email
                            </label>

                            <input asp-for="Email" class="form-control form-control-lg rounded-3"
                                placeholder="Email adresi giriniz">

                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <!-- BUTTONS -->
                        <div class="d-flex justify-content-between">

                            <a asp-action="Index" class="btn btn-outline-secondary">
                                Geri Dön
                            </a>

                            <button type="submit" class="btn btn-dark px-4">
                                Kaydet
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}