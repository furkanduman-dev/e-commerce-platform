@model AccountResetPasswordModel

<style>
    /* Reset Password Page */
    .reset-password-section {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #6f42c1, #6610f2);
        padding: 50px 0;
        font-family: 'Segoe UI', sans-serif;
    }

    .reset-password-section .card {
        border-radius: 12px;
        overflow: hidden;
        transition: transform 0.3s, box-shadow 0.3s;
    }

    .reset-password-section .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
    }

    .reset-password-section .card-header {
        font-weight: bold;
        font-size: 1.3rem;
    }

    .reset-password-section .form-control {
        border-radius: 8px;
        padding: 10px 15px;
        font-size: 0.95rem;
        transition: box-shadow 0.2s, border-color 0.2s;
    }

    .reset-password-section .form-control:focus {
        border-color: #6610f2;
        box-shadow: 0 0 8px rgba(102, 16, 242, 0.3);
    }

    .reset-password-section .btn-primary {
        border-radius: 8px;
        padding: 10px;
        font-weight: 600;
        background: #6610f2;
        border: none;
        transition: background 0.3s;
    }

    .reset-password-section .btn-primary:hover {
        background: #520dc2;
    }

    .reset-password-section .card-footer {
        background: #f8f9fa;
        font-size: 0.8rem;
    }
</style>


<section class="reset-password-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card shadow-sm border-0">
                    <div class="card-header text-center bg-primary text-white">
                        <h3 class="mb-0">Parola Sıfırla</h3>
                    </div>
                    <div class="card-body p-4">
                        <form method="post">
                            <input type="hidden" asp-for="Token">
                            <input type="hidden" asp-for="Email">

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label">Yeni Şifre</label>
                                <input asp-for="Password" type="password" class="form-control"
                                    placeholder="Yeni şifrenizi girin">
                            </div>

                            <div class="mb-3">
                                <label asp-for="ConfirmPassword" class="form-label">Yeni Şifre Tekrar</label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control"
                                    placeholder="Şifrenizi tekrar girin">
                            </div>

                            <button type="submit" class="btn btn-primary w-100">Şifreyi Değiştir</button>
                        </form>
                    </div>
                    <div class="card-footer text-center small text-muted">
                        Güvenliğiniz için şifrenizi kimseyle paylaşmayın.
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>