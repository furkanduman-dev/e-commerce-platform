@model AccountResetPasswordModel

<style>
    /* Reset Password Page – RebelCore Neon Style */
    .reset-password-section {
        min-height: 90vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(120deg, #1a1a2e, #162447);
        font-family: 'Segoe UI', sans-serif;
        padding: 50px 0;
    }

    .neon-card {
        border-radius: 15px;
        overflow: hidden;
        background: #0f0f1e;
        border: 2px solid #6610f2;
        box-shadow: 0 0 20px #6610f2, 0 0 40px #6f42c1;
        transition: transform 0.3s, box-shadow 0.3s;
    }

    .neon-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 0 25px #6610f2, 0 0 50px #6f42c1;
    }

    .neon-header {
        background: linear-gradient(90deg, #6f42c1, #6610f2);
        color: #fff;
        text-shadow: 0 0 5px #fff, 0 0 10px #6f42c1;
    }

    .neon-label {
        color: #ddd;
        text-shadow: 0 0 3px #6f42c1;
    }

    .neon-input {
        border-radius: 10px;
        border: 1px solid #6f42c1;
        padding: 12px 15px;
        background: #1a1a2e;
        color: #fff;
        font-weight: 500;
        transition: all 0.3s;
    }

    .neon-input:focus {
        border-color: #ff4ec2;
        box-shadow: 0 0 10px #ff4ec2;
        background: #1a1a2e;
        color: #fff;
        outline: none;
    }

    .neon-btn {
        border-radius: 12px;
        padding: 12px;
        font-weight: 600;
        background: linear-gradient(90deg, #ff4ec2, #6610f2);
        color: #fff;
        border: none;
        text-shadow: 0 0 5px #fff;
        transition: all 0.3s;
    }

    .neon-btn:hover {
        background: linear-gradient(90deg, #ff2ea2, #520dc2);
        transform: scale(1.03);
        box-shadow: 0 0 15px #ff4ec2, 0 0 30px #6610f2;
    }

    .neon-footer {
        color: #aaa;
        font-size: 0.8rem;
        text-shadow: 0 0 3px #6f42c1;
    }
</style>

<section class="reset-password-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card shadow-lg border-0 neon-card">
                    <div class="card-header text-center neon-header">
                        <h3 class="mb-0">Parola Sıfırla</h3>
                    </div>
                    <div class="card-body p-4">
                        <form method="post">
                            <input type="hidden" asp-for="Token">
                            <input type="hidden" asp-for="Email">

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label neon-label">Yeni Şifre</label>
                                <input asp-for="Password" type="password" class="form-control neon-input"
                                    placeholder="Yeni şifrenizi girin">
                            </div>

                            <div class="mb-3">
                                <label asp-for="ConfirmPassword" class="form-label neon-label">Yeni Şifre Tekrar</label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control neon-input"
                                    placeholder="Şifrenizi tekrar girin">
                            </div>

                            <button type="submit" class="btn neon-btn w-100">Şifreyi Değiştir</button>
                        </form>
                    </div>
                    <div class="card-footer text-center small neon-footer">
                        Güvenliğiniz için şifrenizi kimseyle paylaşmayın.
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>