<style>
    body {
        background: linear-gradient(135deg, #111 0%, #2c3e50 100%);
        min-height: 100vh;
    }

    .forgot-card {
        backdrop-filter: blur(15px);
        background: rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: white;
    }

    .forgot-card h2 {
        font-weight: 700;
        letter-spacing: 1px;
        color: #ffc107;
    }

    .form-control {
        background: rgba(255, 255, 255, 0.1);
        border: none;
        color: white;
    }

    .form-control::placeholder {
        color: rgba(255, 255, 255, 0.6);
    }

    .form-control:focus {
        background: rgba(255, 255, 255, 0.2);
        box-shadow: 0 0 0 0.2rem rgba(255, 193, 7, .4);
        color: white;
    }

    .form-label {
        color: #ddd;
        font-weight: 500;
    }

    .btn-warning {
        background: #ffc107;
        border: none;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-warning:hover {
        background: #ffca2c;
        transform: translateY(-2px);
    }

    a.text-primary {
        text-decoration: none;
        font-weight: 500;
    }

    a.text-primary:hover {
        text-decoration: underline;
    }
</style>

<section class="my-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow-lg forgot-card p-4">
                    <h2 class="text-center mb-4">Şifremi Unuttum</h2>
                    <p style="color: wheat;" class="text-center mb-4">
                        Lütfen kayıtlı e-posta adresinizi girin. Size şifrenizi sıfırlamanız için bir link göndereceğiz.
                    </p>
                    <form method="post">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label for="Email" class="form-label">E-posta</label>
                            <input type="email" id="email" name="email" class="form-control rounded-pill px-4 py-2"
                                placeholder="E-posta adresiniz">
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-warning rounded-pill py-2">
                                Gönder
                            </button>
                        </div>


                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
