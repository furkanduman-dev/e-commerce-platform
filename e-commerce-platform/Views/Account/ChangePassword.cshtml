@model AccountChangePasswordModel

@{
    ViewData["Title"] = "Şifre Değiştir";
}

<style>
    body {
        background: linear-gradient(135deg, #111 0%, #2c3e50 100%);
    }

    .password-card {
        backdrop-filter: blur(15px);
        background: rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: white;
    }

    .form-control {
        background: rgba(255, 255, 255, 0.1);
        border: none;
        color: white;
    }

    .form-control:focus {
        background: rgba(255, 255, 255, 0.2);
        box-shadow: 0 0 0 0.2rem rgba(255, 193, 7, .4);
        color: white;
    }

    .form-label {
        color: #ddd;
    }

    .btn-change {
        background: #ffc107;
        border: none;
        font-weight: 600;
        transition: 0.3s;
    }

    .btn-change:hover {
        background: #ffca2c;
        transform: translateY(-2px);
    }

    .brand-title {
        font-weight: 700;
        letter-spacing: 1px;
    }
</style>

<div class="container vh-100 d-flex align-items-center justify-content-center">
    <div class="row w-100 justify-content-center">
        <div class="col-md-5">

            <div class="password-card shadow-lg p-5">

                <h2 class="text-center mb-4 brand-title">Şifre Değiştir</h2>

                <form asp-action="ChangePassword" method="post">

                    <!-- OLD PASSWORD -->
                    <div class="mb-3">
                        <label asp-for="OldPassword" class="form-label"></label>
                        <input asp-for="OldPassword" class="form-control rounded-pill px-4 py-2"
                            placeholder="Mevcut Şifre">
                        <span asp-validation-for="OldPassword" class="text-warning small"></span>
                    </div>

                    <!-- NEW PASSWORD -->
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control rounded-pill px-4 py-2" placeholder="Yeni Şifre">
                        <span asp-validation-for="Password" class="text-warning small"></span>
                    </div>

                    <!-- CONFIRM PASSWORD -->
                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <input asp-for="ConfirmPassword" class="form-control rounded-pill px-4 py-2"
                            placeholder="Yeni Şifre Tekrar">
                        <span asp-validation-for="ConfirmPassword" class="text-warning small"></span>
                    </div>

                    <!-- BUTTON -->
                    <div class="d-grid">
                        <button type="submit" class="btn btn-change rounded-pill py-2">
                            Şifreyi Güncelle
                        </button>
                    </div>

                </form>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}