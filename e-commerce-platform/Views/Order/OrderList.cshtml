@model List<Order>

<style>
    .card {
        border-radius: 14px;
    }

    .table th {
        font-weight: 600;
    }

    .table-hover tbody tr:hover {
        background: #f8f9fa;
    }
</style>

<section class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Siparişler</h2>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Müşteri</th>
                        <th>Şehir</th>
                        <th>Telefon</th>
                        <th>Tarih</th>
                        <th>Kargo</th>
                        <th>Toplam</th>
                        <th width="120"></th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var order in Model)
                    {
                        <tr>

                            <td>
                                <strong>#@order.Id</strong>
                            </td>

                            <td>
                                @order.Adsoyad
                            </td>

                            <td>
                                @order.Sehir
                            </td>

                            <td>
                                @order.Telefon
                            </td>

                            <td>
                                @order.SiparisTarihi.ToString("dd MMM yyyy")
                            </td>

                            <td>
                                @order.ShippingStatus.Name
                            </td>


                            <td class="fw-bold text-success">
                                ₺@order.Toplam().ToString("0.00")
                            </td>

                            <td>
                                <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-dark">
                                    Detay
                                </a>
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>

</section>
