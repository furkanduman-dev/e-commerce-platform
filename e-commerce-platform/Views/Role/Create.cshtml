@model RoleCreateModel

@{
    ViewData["Title"] = "Yeni Rol Oluştur";
}

<div class="container py-5">

    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-dark text-white rounded-top-4">
                    <h4 class="mb-0">Yeni Rol Oluştur</h4>
                </div>

                <div class="card-body p-4">

                    <form asp-action="Create" method="post">

                        <!-- ROLE NAME -->
                        <div class="mb-4">
                            <label asp-for="RoleName" class="form-label fw-semibold">
                                Rol Adı
                            </label>

                            <input asp-for="RoleName"
                                   class="form-control form-control-lg rounded-3"
                                   placeholder="Örn: Admin, Editor, Customer">

                            <span asp-validation-for="RoleName"
                                  class="text-danger small"></span>
                        </div>

                        <!-- BUTTONS -->
                        <div class="d-flex justify-content-between">

                            <a asp-action="Index" class="btn btn-outline-secondary">
                                Geri Dön
                            </a>

                            <button type="submit" class="btn btn-dark px-4">
                                Kaydet
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>

</div>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
}